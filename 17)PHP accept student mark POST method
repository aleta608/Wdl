<?php
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $name = $_POST['name'];
    $m1 = $_POST['m1'];
    $m2 = $_POST['m2'];
    $m3 = $_POST['m3'];

    $upperName = strtoupper($name);
    $length = strlen($name);

    $marks = array($m1, $m2, $m3);
    $total = array_sum($marks);
    $avg = $total / count($marks);

    echo "<h3>Result</h3>";
    echo "Name (Uppercase): $upperName <br>";
    echo "Name Length: $length <br>";
    echo "Total Marks: $total <br>";
    echo "Average: " . round($avg, 2);
}
