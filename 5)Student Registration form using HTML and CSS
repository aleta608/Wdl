<!DOCTYPE html> 
<html> 
<head> 
    <title>Student Registration</title> 
    <style> 
        body { 
            font-family: Arial; 
            background: #eef2f3; 
        } 
        .container { 
            width: 400px; 
            margin: auto; 
            background: white; 
            padding: 20px; 
            margin-top: 50px; 
            border-radius: 10px; 
            box-shadow: 0 0 10px gray; 
        } 
        h2 { 
            text-align: center; 
        } 
        input { 
            width: 100%; 
            padding: 8px; 
            margin: 8px 0; 
        } 
        .btn { 
            background: blue; 
            color: white; 
            border: none; 
            cursor: pointer; 
        } 
        .btn:hover { 
            background: darkblue; 
        } 
    </style> 
</head> 
<body> 
<div class="container"> 
    <h2>Student Registration Form</h2> 
    <form> 
        Name: 
        <input type="text" placeholder="Enter your name" required> 
        Email: 
        <input type="email" placeholder="Enter your email" required> 
        Gender:<br> 
        <input type="radio" name="gender"> Male 
        <input type="radio" name="gender"> Female<br><br> 
        Date of Birth: 
        <input type="date"> 
        <input type="submit" value="Register" class="btn"> 
    </form> 
</div> 
</body> 
</html>
