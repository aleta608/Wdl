<!DOCTYPE html> 
<html> 
<head> 
    <title>Survey Form</title> 
    <style> 
        body { 
            font-family: Arial; 
            background-color: #50caf3; 
        } 
        .container { 
            width: 400px; 
            margin: auto; 
            background: lab(83.63% -27.97 81.86); 
            padding: 20px; 
            border-radius: 10px; 
            box-shadow: 0px 0px 10px gray; 
        } 
        h2 { 
            text-align: center; 
        } 
        input, select { 
            width: 100%; 
            padding: 8px; 
            margin: 5px 0; 
        } 
        .btn { 
            background-color: rgb(245, 106, 106); 
            color: white; 
            border: none; 
            cursor: pointer; 
        } 
        .btn:hover { 
            background-color: rgb(119, 119, 251); 
        } 
    </style> 
</head> 
<body> 
<div class="container"> 
    <h2>Survey Form</h2> 
    <form> 
        Name: 
        <input type="text" placeholder="Enter your name" required style="color: rgb(254, 253, 254); background-color: rgb(245, 102, 240);"> 

        Email: 
        <input type="email" placeholder="Enter your email" required style="color: rgb(247, 242, 247); background-color: rgb(254, 253, 254);"> 

        Age: 
        <input type="number"> 

        Gender:<br> 
        <input type="radio" name="gender"> Male 
        <input type="radio" name="gender"> Female<br><br> 

        Interests:<br> 
        <input type="checkbox"> Coding 
        <input type="checkbox"> Sports 
        <input type="checkbox"> Music<br><br> 

        Favorite Language: 
        <select> 
            <option>HTML</option> 
            <option>CSS</option> 
            <option>JavaScript</option> 
        </select> 

        Feedback: 
        <input type="text" placeholder="Your feedback"> 

        <input type="submit" value="Submit" class="btn"> 
    </form> 
</div> 
</body> 
</html>
