<!DOCTYPE html>
<html>
<body>

<form onsubmit="return validate()">
Email: <input type="text" id="email"><br><br>
<button type="submit">Submit</button>
</form>

<script>
function validate() {
  let email = document.getElementById("email").value;

  if (email == "" || !email.includes("@")) {
    alert("Invalid Email");
    return false;
  }

  alert("Valid Email");
  return true;
}
</script>

</body>
</html>
