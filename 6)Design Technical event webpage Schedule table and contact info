<!DOCTYPE html> 
<html> 
<head> 
    <title>I2IT TechCon 2025</title> 
    <style> 
        body { 
            font-family: Arial; 
            margin: 0; 
            background: #f4f4f4; 
        } 
        header { 
            background: #1e90ff; 
            color: white; 
            text-align: center; 
            padding: 30px; 
        } 
        nav { 
            background: #333; 
            padding: 10px; 
            text-align: center; 
        } 
        nav a { 
            color: white; 
            margin: 15px; 
            text-decoration: none; 
            font-weight: bold; 
        } 
        nav a:hover { 
            color: orange; 
        } 
        .container { 
            padding: 20px; 
        } 
        table { 
            width: 100%; 
            border-collapse: collapse; 
            margin-top: 20px; 
            background: white; 
        } 
        th, td { 
            border: 1px solid black; 
            padding: 10px; 
            text-align: center; 
        } 
        th { 
            background: #1e90ff; 
            color: white; 
        } 
        tr:hover { 
            background: #ddd; 
        } 
        form { 
            margin-top: 20px; 
            background: white; 
            padding: 15px; 
            border-radius: 10px; 
        } 
        input, textarea { 
            width: 100%; 
            padding: 8px; 
            margin: 8px 0; 
        } 
        .btn { 
            background: #1e90ff; 
            color: white; 
            border: none; 
            cursor: pointer; 
        } 
        .btn:hover { 
            background: #0d6efd; 
        } 
    </style> 
</head> 
<body> 

<header> 
    <h1>I2IT TechCon 2025</h1> 
    <p>Welcome to the Annual Technical Conference</p> 
</header> 

<nav> 
    <a href="#">About</a> 
    <a href="#">Schedule</a> 
    <a href="#">Contact</a> 
</nav> 

<div class="container"> 

    <h2>About Event</h2> 
    <p>TechCon 2025 is a platform for students and professionals to showcase their technical skills and innovations.</p> 

    <h2>Event Schedule</h2> 
    <table> 
        <tr> 
            <th>Time</th> 
            <th>Event</th> 
        </tr> 
        <tr> 
            <td>10:00 AM</td> 
            <td>Inauguration</td> 
        </tr> 
        <tr> 
            <td>11:00 AM</td> 
            <td>Technical Paper Presentation</td> 
        </tr> 
        <tr> 
            <td>2:00 PM</td> 
            <td>Workshop</td> 
        </tr> 
        <tr> 
            <td>4:00 PM</td> 
            <td>Closing Ceremony</td> 
        </tr> 
    </table> 

    <h2>Contact Us</h2> 
    <form> 
        Name: 
        <input type="text" placeholder="Enter your name" required> 

        Email: 
        <input type="email" placeholder="Enter your email" required> 

        Message: 
        <textarea rows="4" placeholder="Enter your message"></textarea> 

        <input type="submit" value="Send Message" class="btn"> 
    </form> 

</div> 

</body> 
</html>
